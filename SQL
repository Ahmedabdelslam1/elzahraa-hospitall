CREATE TABLE patients (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100),
    phone VARCHAR(20),
    birth_date DATE,
    gender VARCHAR(10),
    insurance VARCHAR(100),
    notes TEXT
);

CREATE TABLE doctors (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100),
    specialty VARCHAR(50),
    visit_price DECIMAL
);

CREATE TABLE visits (
    id SERIAL PRIMARY KEY,
    patient_id INT REFERENCES patients(id),
    doctor_id INT REFERENCES doctors(id),
    visit_date TIMESTAMP,
    queue_number INT,
    diagnosis TEXT,
    treatment TEXT
);

CREATE TABLE lab (
    id SERIAL PRIMARY KEY,
    patient_id INT REFERENCES patients(id),
    test_name VARCHAR(100),
    price DECIMAL,
    result TEXT,
    attachment TEXT,
    date TIMESTAMP
);

CREATE TABLE expenses (
    id SERIAL PRIMARY KEY,
    name VARCHAR(100),
    amount DECIMAL,
    date TIMESTAMP
);

CREATE TABLE users (
    id SERIAL PRIMARY KEY,
    username VARCHAR(50),
    password_hash VARCHAR(255),
    role VARCHAR(20)
);
